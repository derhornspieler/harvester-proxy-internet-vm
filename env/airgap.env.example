# =============================================================================
# Airgap Simulation — Environment Overrides
# =============================================================================
# Copy to ../scripts/.env and merge with existing values.
# Replace <PROXY_VM_IP> with the actual IP of your airgap proxy VM
# (e.g., 10.0.0.100 for your proxy VM).
#
# This file is the single source of truth for airgap env vars.
# See also: scripts/.env.example.airgap (identical content).
# =============================================================================

# === Core Airgap Flag ===
AIRGAPPED="true"
AIRGAP_PROXY_HOST="<PROXY_VM_IP>"

# === Bootstrap Registry (Docker registry on proxy VM, Phases 0-4) ===
# Pre-existing external registry containing RKE2 system images, Helm charts (OCI),
# and all container images for Phases 0-4 (before in-cluster Harbor exists).
# Populated by: ./scripts/prepare-bootstrap-registry.sh
BOOTSTRAP_REGISTRY="${AIRGAP_PROXY_HOST}:5000"

# Harbor proxy-cache upstream (used by Harbor after Phase 4).
# Harbor's proxy-cache projects fetch from this registry instead of the internet.
# In most airgapped deployments this equals BOOTSTRAP_REGISTRY.
# For real airgap: could be a corporate proxy, Nexus, or any accessible registry.
UPSTREAM_PROXY_REGISTRY="${AIRGAP_PROXY_HOST}:5000"

# PEM-encoded CA cert for bootstrap registry TLS (if self-signed).
# For the simulation proxy VM, use the ca-chain.pem generated by the PKI:
#   BOOTSTRAP_REGISTRY_CA_PEM="$(cat airgap-simulation/certs/ca-chain.pem)"
BOOTSTRAP_REGISTRY_CA_PEM=""

# Optional: authentication for bootstrap registry
BOOTSTRAP_REGISTRY_USERNAME=""
BOOTSTRAP_REGISTRY_PASSWORD=""

# === Private RPM Repos (yum.$DOMAIN nginx proxy) ===
# Required when AIRGAPPED=true — Rocky Linux + RKE2 package mirrors
PRIVATE_ROCKY_REPO_URL="https://yum.example.com"
PRIVATE_RKE2_REPO_URL="https://yum.example.com"

# === Git (use internal GitLab once deployed, or GitHub for simulation) ===
GIT_BASE_URL="git@github.com:<YOUR_ORG>"

# === Binary URLs (bin.$DOMAIN static serve) ===
# Point to internal HTTP mirror. The airgap proxy VM serves these via nginx.
BINARY_URL_ARGOCD_CLI="https://bin.example.com/argoproj/argo-cd/releases/latest/download/argocd-linux-amd64"
BINARY_URL_KUSTOMIZE="https://bin.example.com/kubernetes-sigs/kustomize/releases/download/kustomize/v5.6.0/kustomize_v5.6.0_linux_amd64.tar.gz"
BINARY_URL_KUBECONFORM="https://bin.example.com/yannh/kubeconform/releases/download/v0.6.7/kubeconform-linux-amd64.tar.gz"

# CRD JSON schema catalog base URL (used by kubeconform in CI)
CRD_SCHEMA_BASE_URL="https://bin.example.com/datreeio/CRDs-catalog/main"

# Gateway API CRDs (alternative: pre-download to crds/gateway-api-v1.3.0-experimental-install.yaml)
GATEWAY_API_CRD_URL="https://bin.example.com/kubernetes-sigs/gateway-api/releases/download/v1.3.0/experimental-install.yaml"

# Argo Rollouts Gateway API plugin binary
ARGO_ROLLOUTS_PLUGIN_URL="https://bin.example.com/argoproj-labs/rollouts-plugin-trafficrouter-gatewayapi/releases/download/v0.5.0/gateway-api-plugin-linux-amd64"

# === Helm OCI URLs (charts served from Harbor or bootstrap registry) ===
# These override the default Helm repo URLs. In airgapped mode, charts are
# pulled as OCI artifacts from Harbor's proxy-cache projects.
# Project naming convention: repo URL hostname becomes the Harbor project name.
HELM_OCI_CERT_MANAGER="oci://harbor.example.com/charts.jetstack.io/cert-manager"
HELM_OCI_CNPG="oci://harbor.example.com/cloudnative-pg.github.io/cloudnative-pg"
HELM_OCI_CLUSTER_AUTOSCALER="oci://harbor.example.com/kubernetes.github.io/cluster-autoscaler"
HELM_OCI_REDIS_OPERATOR="oci://harbor.example.com/ot-container-kit.github.io/redis-operator"
HELM_OCI_VAULT="oci://harbor.example.com/helm.releases.hashicorp.com/vault"
HELM_OCI_HARBOR="oci://harbor.example.com/helm.goharbor.io/harbor"
HELM_OCI_KPS="oci://harbor.example.com/prometheus-community.github.io/kube-prometheus-stack"
HELM_OCI_KASM="oci://harbor.example.com/helm.kasmweb.com/kasm"
HELM_OCI_GITLAB_RUNNER="oci://harbor.example.com/charts.gitlab.io/gitlab-runner"
HELM_OCI_EXTERNAL_SECRETS="oci://harbor.example.com/charts.external-secrets.io/external-secrets"
HELM_OCI_MARIADB_OPERATOR="oci://harbor.example.com/mariadb-operator.github.io/mariadb-operator"
HELM_OCI_ARGOCD="oci://harbor.example.com/ghcr.io/argoproj/argo-helm/argo-cd"
HELM_OCI_ARGO_ROLLOUTS="oci://harbor.example.com/ghcr.io/argoproj/argo-helm/argo-rollouts"
HELM_OCI_ARGO_WORKFLOWS="oci://harbor.example.com/ghcr.io/argoproj/argo-helm/argo-workflows"
HELM_OCI_ARGO_EVENTS="oci://harbor.example.com/ghcr.io/argoproj/argo-helm/argo-events"

# === CI Dependency Proxies (soft warnings if unset) ===
CI_GOPROXY="off"
CI_GONOSUMDB="*"
CI_NPM_REGISTRY=""
CI_PIP_INDEX_URL=""
